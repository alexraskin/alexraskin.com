---
import "@fortawesome/fontawesome-free/css/all.css";
import "@fontsource-variable/outfit";
import "../tailwind.css";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="My Personal Website" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="//gavn.in/fav" />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-mobile lg:min-h-screen bg-neutral-200">
    <slot />
  </body>
</html>
