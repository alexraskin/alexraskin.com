---
import "@fortawesome/fontawesome-free/css/all.css";
import "@fontsource-variable/outfit";
import "../tailwind.css";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="My Personal Website" />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content="Alex Raskin" />
    <meta property="og:title" content="alexraskin.com">
    <meta property="og:url" content="https://alexraskin.com">
    <meta property="og:type" content="website">
    <meta property="og:description" content="My Personal Website">
    <meta property="og:image" content="https://i.gyazo.com/25c488354f92b0f83cccc22daff60d18.jpg">
    <link rel="icon" type="image/svg+xml" href="https://i.gyazo.com/2dd7e0c96375088beadc2814791b178b.jpg" />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-mobile lg:min-h-screen bg-neutral-200">
    <slot />
  </body>
</html>
